{
  "rules": [
    {
      "id": "extermination",
      "trigger": "kill",
      "blueprint": "mother_plant",
      "result": "win",
      "outcome": "extermination",
      "message": "The mother plant is dead. The infestation collapses."
    },
    {
      "id": "saboteur_escape",
      "trigger": "interaction",
      "interaction": "life_pod_escape",
      "when": [
        {"player_background": "saboteur"},
        {"game_flag": "mother_plant_placed"}
      ],
      "result": "win",
      "outcome": "saboteur",
      "message": "You've been paid. The station burns behind you."
    },
    {
      "id": "saboteur_caught",
      "trigger": "interaction",
      "interaction": "life_pod_escape",
      "when": [
        {"player_background": "saboteur"},
        {"entity_count": {"blueprint": "mother_plant", "op": "eq", "value": 0}}
      ],
      "result": "lose",
      "outcome": "saboteur_caught",
      "message": "You tried to flee without completing your mission."
    },
    {
      "id": "escape_selfish",
      "trigger": "interaction",
      "interaction": "life_pod_escape",
      "result": "win",
      "outcome": "escape_selfish",
      "message": "You escape the station alone. The airlock seals behind you."
    },
    {
      "id": "heroic_death",
      "trigger": "player_death",
      "when": [{"game_flag": "self_destruct_armed"}],
      "result": "win",
      "outcome": "heroic_death",
      "message": "You stay behind to ensure the station is destroyed. A hero's end."
    },
    {
      "id": "player_death_default",
      "trigger": "player_death",
      "result": "lose",
      "outcome": "dead",
      "message": ""
    }
  ]
}
