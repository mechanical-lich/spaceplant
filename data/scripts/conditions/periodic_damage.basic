function on_applied():
    add_message("A harmful effect takes hold.")
endfunction

function on_turn():
    let amt = get_var("damage_amount")
    if amt == 0 then amt = 1
    let dtype = get_var("damage_type")
    if dtype == "" then dtype = "physical"
    deal_damage(amt, dtype)
endfunction

function on_removed():
    add_message("The effect fades.")
endfunction
