func on_applied()
    add_message("A harmful effect takes hold.")
endfunc

func on_turn()
    amt = get_var("damage_amount")
    if amt == 0 then amt = 1
    dtype = get_var("damage_type")
    if dtype == "" then dtype = "physical"
    deal_damage(amt, dtype)
endfunc

func on_removed()
    add_message("The effect fades.")
endfunc
